# Backend environment variables.
# Copy to `.env` and fill in real values. Do NOT commit your `.env`.

# --- Database ---
# MongoDB connection string. For Docker Compose use: mongodb://mongodb:27017/data-analyzer
MONGODB_URI=mongodb://localhost:27017/data-analyzer

# --- Security ---
# Strong random secret used to sign JWTs. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated list of origins allowed by CORS (the frontend URL(s)).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# --- LLM (Google Gemini) ---
# API key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# --- Uploads ---
# Maximum upload size in megabytes.
MAX_UPLOAD_MB=50
